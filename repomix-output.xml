                                <th>Tuyến</th>
                                <th>Xe</th>
                                <th>Tài xế</th>
                                <th>Phụ xe</th>
                                <th>Khởi hành</th>
                                <th>Ghế</th>
                                <th>Giá</th>
                                <th>Trạng thái</th>
                                <th>Hành động</th>
