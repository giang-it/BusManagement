<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">

<head>
    <title>Thêm Xe Mới</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">
    <div class="container mt-5">
        <div class="card shadow">
            <div class="card-header bg-primary text-white">
                <h3 class="mb-0">🚌 Thêm Xe Khách Mới</h3>
            </div>
            <div class="card-body">
                <form th:action="@{/admin/buses/save}" th:object="${bus}" method="post">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Biển số xe</label>
                            <input type="text" th:field="*{licensePlate}" class="form-control"
                                placeholder="Ví dụ: 29A-123.45" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Hãng xe (Brand)</label>
                            <input type="text" th:field="*{brand}" class="form-control"
                                placeholder="Ví dụ: Thaco, Hyundai">
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Loại xe</label>
                            <select th:field="*{busType}" class="form-select">
                                <option th:each="type : ${busTypes}" th:value="${type.id}"
                                    th:text="${type.typeName} + ' (' + ${type.capacity} + ' ghế)'">
                                </option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Trạng thái vận hành</label>
                            <select th:field="*{status}" class="form-select">
                                <option th:each="st : ${statuses}" th:value="${st}" th:text="${st}"></option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Số KM hiện tại</label>
                        <input type="number" step="0.1" th:field="*{odometer}" class="form-control" value="0">
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-success px-4">Lưu thông tin</button>
                        <a href="/admin/dashboard" class="btn btn-secondary px-4">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</body>

</html>
