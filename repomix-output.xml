                                                          trip.status.name() == 'COMPLETED' ? 'bg-info' :
                                                          trip.status.name() == 'CANCELLED' ? 'bg-danger' :
                                                          'bg-secondary'}" th:text="${trip.status.name()}">
                                    </span>
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm" role="group">
                                        <a th:href="@{/admin/trip-management/trips/edit/{id}(id=${trip.id})}"
