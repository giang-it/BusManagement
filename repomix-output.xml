                    </div>
                    <div class="card-body p-4">
                        <form
                            th:action="${bus.id == null} ? @{/admin/buses/create} : @{/admin/buses/edit/{id}(id=${bus.id})}"
                            th:object="${bus}" method="post" class="needs-validation" novalidate>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Biển Số Xe <span
                                            class="text-danger">*</span></label>
                                    <input type="text" class="form-control text-uppercase" th:field="*{licensePlate}"
                                        required placeholder="Ví dụ: 51B-123.45">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Hãng Xe <span
                                            class="text-danger">*</span></label>
                                    <input type="text" class="form-control" th:field="*{brand}" required
                                        placeholder="Thaco, Huyndai...">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Cấu Hình Loại Xe <span
                                            class="text-danger">*</span></label>
                                    <select class="form-select" th:field="*{busType}" required>
                                        <option value="" disabled selected>-- Chọn loại xe --</option>
                                        <option th:each="type : ${busTypes}" th:value="${type.id}"
                                            th:text="${type.typeName} + ' (' + ${type.capacity} + ' Ghế)'"></option>
                                    </select>
                                    <div class="form-text text-muted">ℹ️ Số ghế xe tự động quyết định dựa trên Loại xe
                                        đã chọn để tránh sai sót.</div>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Trạng Thái Vận Hành <span
                                            class="text-danger">*</span></label>
                                    <select class="form-select" th:field="*{status}" required>
                                        <option th:each="st : ${statuses}" th:value="${st.name()}"
                                            th:text="${st.name()}"></option>
                                    </select>
                                </div>
                                <hr class="my-4">
                                <h5 class="text-muted"><i class="bi bi-speedometer2"></i> Thông Số Bảo Trì Định Kỳ</h5>
                                <div class="col-md-4">
                                    <label class="form-label">Odometer Hiện Tại (Km)</label>
                                    <input type="number" step="0.1" class="form-control" th:field="*{odometer}">
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Km Lần Bảo Trì Cuối</label>
                                    <input type="number" step="0.1" class="form-control"
                                        th:field="*{lastMaintenanceOdometer}">
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Ngưỡng Cảnh Báo (Km)</label>
                                    <input type="number" step="0.1" class="form-control"
                                        th:field="*{maintenanceThreshold}">
                                </div>
                            </div>
                            <div class="d-flex justify-content-end mt-4">
                                <a href="/admin/buses" class="btn btn-outline-secondary me-2">Hủy Bỏ</a>
