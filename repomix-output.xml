                        </a>
                    </div>

                    <!-- Hàng 2 -->
                    <div class="col-md-4 mb-3">
                        <a th:href="@{/admin/buses}" class="btn btn-outline-secondary btn-lg w-100 py-4 shadow-sm">
                            <i class="bi bi-tags fs-1"></i><br><span class="mt-2 d-block">Quản Lý Loại Xe</span>
