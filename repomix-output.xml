            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>

        <div th:if="${error}" class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle"></i> <span th:text="${error}"></span>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>

        <!-- Filter & Actions -->
        <div class="card mb-4">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-md-8">
                        <form action="/admin/trip-management/trips/filter" method="get" class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label">Lọc theo trạng thái</label>
                                <select name="status" class="form-select">
                                    <option value="">-- Tất cả trạng thái --</option>
                                    <option th:each="status : ${statuses}" th:value="${status.name()}"
                                        th:text="${status.name()}" th:selected="${selectedStatus == status.name()}">
                                    </option>
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">&nbsp;</label>
                                <button type="submit" class="btn btn-primary w-100">
                                    <i class="fas fa-filter"></i> Lọc
                                </button>
                            </div>
                        </form>
                    </div>
                    <div class="col-md-4 text-end">
                        <a href="/admin/trip-management/trips/create" class="btn btn-success">
                            <i class="fas fa-plus"></i> Tạo chuyến mới
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Statistics -->
