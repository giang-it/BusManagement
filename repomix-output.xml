                                    <li>Địa chỉ nên đầy đủ để khách hàng dễ tìm kiếm</li>
                                    <li>Sau khi tạo trạm, bạn có thể gán trạm vào các tuyến đường</li>
                                </ul>
                            </div>

                            <div class="d-flex justify-content-between mt-4">
                                <a href="/admin/master-data/stations" class="btn btn-secondary">
                                    <i class="fas fa-times"></i> Hủy
                                </a>
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-save"></i> Lưu
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
</file>

<file path="BusManagement/src/main/resources/templates/admin/station-list.html">
<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý Trạm</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
</head>

<body class="bg-light">
    <nav class="navbar navbar-dark bg-dark mb-4">
        <div class="container-fluid">
            <span class="navbar-brand mb-0 h1">
                <i class="fas fa-map-marker-alt"></i> Quản lý Trạm
            </span>
            <a href="/admin/dashboard" class="btn btn-outline-light btn-sm">
                <i class="fas fa-home"></i> Dashboard
            </a>
        </div>
    </nav>

    <div class="container">
        <!-- Alert Messages -->
        <div th:if="${success}" class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> <span th:text="${success}"></span>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>

        <div th:if="${error}" class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle"></i> <span th:text="${error}"></span>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>

        <!-- Statistics -->
        <div class="row mb-4">
            <div class="col-md-12">
                <div class="card border-primary">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-1">Tổng số trạm</h6>
                                <h3 class="mb-0" th:text="${stations.size()}">0</h3>
                            </div>
                            <div style="font-size: 3rem; opacity: 0.7;" class="text-primary">
                                <i class="fas fa-map-marked-alt"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Danh sách trạm -->
        <div class="card shadow">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="fas fa-list"></i> Danh sách trạm
                </h5>
                <a href="/admin/master-data/stations/form" class="btn btn-light btn-sm">
                    <i class="fas fa-plus"></i> Thêm trạm mới
                </a>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>ID</th>
                                <th>Tên trạm</th>
                                <th>Địa chỉ</th>
                                <th>Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr th:each="station : ${stations}">
                                <td th:text="${station.id}"></td>
                                <td>
                                    <i class="fas fa-map-marker-alt text-danger"></i>
                                    <strong th:text="${station.stationName}"></strong>
                                </td>
                                <td th:text="${station.address}"></td>
                                <td>
                                    <div class="btn-group btn-group-sm" role="group">
                                        <a th:href="@{/admin/master-data/stations/form(id=${station.id})}"
                                            class="btn btn-outline-primary" title="Sửa">
                                            <i class="fas fa-edit"></i> Sửa
                                        </a>
                                        <form th:action="@{/admin/master-data/stations/delete/{id}(id=${station.id})}"
                                            method="post" style="display: inline;">
                                            <button type="submit" class="btn btn-outline-danger btn-sm"
                                                onclick="return confirm('Xác nhận xóa trạm này?')" title="Xóa">
                                                <i class="fas fa-trash"></i> Xóa
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                            <tr th:if="${stations.isEmpty()}">
                                <td colspan="4" class="text-center text-muted py-5">
                                    <i class="fas fa-info-circle fs-3"></i><br>
                                    Chưa có trạm nào trong hệ thống. Hãy thêm trạm mới!
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Info box -->
        <div class="alert alert-info mt-4">
            <i class="fas fa-info-circle"></i>
            <strong>Lưu ý:</strong> Trạm là các điểm dừng trên tuyến đường.
            Mỗi tuyến có thể có nhiều trạm dừng giữa điểm đi và điểm đến.
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
</file>

<file path="BusManagement/src/main/resources/templates/admin/suggestions.html">
<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">

<head>
    <title>Đề xuất tăng cường xe</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>

<body class="container mt-5">
    <h2>Hệ thống dự báo nhu cầu (AI Rule-based)</h2>
    <p class="text-muted">Các chuyến xe dưới đây được hệ thống tự động đề xuất dựa trên tỷ lệ đặt chỗ cao.</p>

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Lộ trình</th>
                <th>Giờ khởi hành</th>
                <th>Giá vé</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            <tr th:each="trip : ${suggestions}">
                <td th:text="${trip.route}"></td>
                <td th:text="${#temporals.format(trip.departureTime, 'dd-MM-yyyy HH:mm')}"></td>
                <td th:text="${trip.price}"></td>
                <td>
                    <form th:action="@{/admin/trips/approve/{id}(id=${trip.id})}" method="post">
                        <button class="btn btn-success btn-sm">Duyệt mở chuyến</button>
                    </form>
                </td>
            </tr>
            <tr th:if="${suggestions.empty}">
                <td colspan="4" class="text-center">Hiện chưa có đề xuất nào từ hệ thống.</td>
            </tr>
        </tbody>
    </table>
</body>

</html>
</file>

<file path="BusManagement/src/main/resources/templates/admin/trip-create-form.html">
<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tạo Chuyến xe</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
</head>

<body class="bg-light">
    <nav class="navbar navbar-dark bg-dark mb-4">
        <div class="container-fluid">
            <span class="navbar-brand mb-0 h1">
                <i class="fas fa-plus-circle"></i> Tạo Chuyến xe thủ công
            </span>
            <a href="/admin/trip-management/trips" class="btn btn-outline-light btn-sm">
                <i class="fas fa-arrow-left"></i> Quay lại
            </a>
        </div>
    </nav>

    <div class="container">
        <div class="card shadow">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0">
                    <i class="fas fa-edit"></i> Thông tin chuyến xe
                </h5>
            </div>
            <div class="card-body">
                <form action="/admin/trip-management/trips/create" method="post">

                    <!-- CHỌN TUYẾN -->
                    <h6 class="border-bottom pb-2 mb-3">
                        <i class="fas fa-route"></i> Thông tin tuyến đường
                    </h6>
                    <div class="row">
                        <div class="col-md-12 mb-3">
                            <label class="form-label">
                                Tuyến đường <span class="text-danger">*</span>
                            </label>
                            <select name="routeId" class="form-select" required>
                                <option value="">-- Chọn tuyến --</option>
                                <option th:each="route : ${routes}" th:value="${route.id}"
                                    th:text="${route.departurePoint} + ' → ' + ${route.destinationPoint}">
                                </option>
                            </select>
                        </div>
                    </div>

                    <!-- CHỌN XE VÀ TÀI XẾ -->
                    <h6 class="border-bottom pb-2 mb-3 mt-4">
                        <i class="fas fa-bus"></i> Phân công xe & nhân sự
                    </h6>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">
                                <i class="fas fa-bus"></i> Xe <span class="text-danger">*</span>
                            </label>
                            <select name="busId" class="form-select" required>
                                <option value="">-- Chọn xe --</option>
                                <option th:each="bus : ${buses}" th:value="${bus.id}"
                                    th:text="${bus.licensePlate} + ' (' + ${bus.busType?.typeName} + ')'">
                                </option>
                            </select>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label class="form-label">
                                <i class="fas fa-user-tie"></i> Tài xế chính <span class="text-danger">*</span>
                            </label>
                            <select name="driverId" class="form-select" required>
                                <option value="">-- Chọn tài xế --</option>
                                <option th:each="driver : ${drivers}" th:value="${driver.userId}"
                                    th:text="${driver.user?.fullName}">
                                </option>
                            </select>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label class="form-label">
                                <i class="fas fa-user"></i> Phụ xe (tùy chọn)
                            </label>
                            <select name="assistantId" class="form-select">
                                <option value="">-- Không có --</option>
                                <option th:each="driver : ${drivers}" th:value="${driver.userId}"
                                    th:text="${driver.user?.fullName}">
                                </option>
                            </select>
                            <div class="form-text">Phụ xe hỗ trợ bán vé và chăm sóc khách</div>
                        </div>
                    </div>

                    <!-- THỜI GIAN -->
                    <h6 class="border-bottom pb-2 mb-3 mt-4">
                        <i class="fas fa-clock"></i> Thời gian
                    </h6>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">
                                <i class="fas fa-calendar-day"></i> Thời gian khởi hành <span
                                    class="text-danger">*</span>
                            </label>
                            <input type="datetime-local" name="departureTime" class="form-control" required>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">
                                <i class="fas fa-calendar-check"></i> Thời gian đến dự kiến <span
                                    class="text-danger">*</span>
                            </label>
                            <input type="datetime-local" name="arrivalTimeExpected" class="form-control" required>
                        </div>
                    </div>

                    <!-- GHẾ VÀ GIÁ -->
                    <h6 class="border-bottom pb-2 mb-3 mt-4">
                        <i class="fas fa-tags"></i> Ghế ngồi & Giá vé
                    </h6>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">
                                <i class="fas fa-chair"></i> Tổng số ghế <span class="text-danger">*</span>
                            </label>
                            <input type="number" name="totalSeats" class="form-control" required min="1" max="100"
                                placeholder="40">
                            <div class="form-text">Số ghế thực tế trên xe</div>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">
                                <i class="fas fa-dollar-sign"></i> Giá vé (VNĐ) <span class="text-danger">*</span>
                            </label>
                            <input type="number" name="price" class="form-control" required min="0" step="1000"
                                placeholder="150000">
                            <div class="form-text">Giá vé một ghế</div>
                        </div>
                    </div>

                    <!-- CẢNH BÁO -->
                    <div class="alert alert-warning">
                        <h6><i class="fas fa-exclamation-triangle"></i> Lưu ý khi tạo chuyến:</h6>
                        <ul class="mb-0">
                            <li><strong>Xe:</strong> Đảm bảo xe đang ở trạng thái READY (không trong bảo trì)</li>
                            <li><strong>Tài xế:</strong> Kiểm tra tài xế chưa lái quá 8h trong 24h qua</li>
                            <li><strong>Tài xế:</strong> Đảm bảo tài xế đã nghỉ đủ 2 ngày/tháng</li>
                            <li><strong>Thời gian:</strong> Thời gian đến phải sau thời gian khởi hành</li>
                            <li><strong>Ghế:</strong> Số ghế phải khớp với xe được chọn</li>
                        </ul>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <a href="/admin/trip-management/trips" class="btn btn-secondary">
                            <i class="fas fa-times"></i> Hủy
                        </a>
                        <button type="submit" class="btn btn-success">
                            <i class="fas fa-save"></i> Tạo chuyến
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Hướng dẫn -->
        <div class="card mt-4">
            <div class="card-header bg-info text-white">
                <h6 class="mb-0"><i class="fas fa-question-circle"></i> Hướng dẫn</h6>
            </div>
            <div class="card-body">
                <ol>
                    <li><strong>Chọn tuyến:</strong> Chọn tuyến đường đã được cấu hình sẵn</li>
                    <li><strong>Gán xe & tài xế:</strong> Hệ thống sẽ kiểm tra ràng buộc tự động</li>
                    <li><strong>Phụ xe:</strong> Tùy chọn, giúp hỗ trợ bán vé và chăm sóc khách</li>
                    <li><strong>Đặt thời gian:</strong> Thời gian khởi hành phải là tương lai</li>
                    <li><strong>Giá vé:</strong> Có thể tham khảo bảng giá đã cấu hình cho tuyến</li>
                </ol>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
</file>

<file path="BusManagement/src/main/resources/templates/admin/trip-edit-form.html">
<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sửa Chuyến xe</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
</head>

<body class="bg-light">
    <nav class="navbar navbar-dark bg-dark mb-4">
        <div class="container-fluid">
            <span class="navbar-brand mb-0 h1">
                <i class="fas fa-edit"></i> Sửa Chuyến xe #<span th:text="${trip.id}"></span>
            </span>
            <a href="/admin/trip-management/trips" class="btn btn-outline-light btn-sm">
                <i class="fas fa-arrow-left"></i> Quay lại
            </a>
        </div>
    </nav>

    <div class="container">
        <div class="card shadow">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">
                    <i class="fas fa-edit"></i> Cập nhật thông tin chuyến xe
                </h5>
            </div>
            <div class="card-body">
                <form action="/admin/trip-management/trips/update" method="post">
                    <input type="hidden" name="id" th:value="${trip.id}">

                    <!-- CHỌN TUYẾN -->
                    <h6 class="border-bottom pb-2 mb-3">
                        <i class="fas fa-route"></i> Thông tin tuyến đường
                    </h6>
                    <div class="row">
                        <div class="col-md-12 mb-3">
                            <label class="form-label">
                                Tuyến đường <span class="text-danger">*</span>
                            </label>
                            <select name="routeId" class="form-select" required>
                                <option value="">-- Chọn tuyến --</option>
                                <option th:each="route : ${routes}" th:value="${route.id}"
                                    th:text="${route.departurePoint} + ' → ' + ${route.destinationPoint}"
                                    th:selected="${route.id == trip.route?.id}">
                                </option>
                            </select>
                        </div>
                    </div>

                    <!-- CHỌN XE VÀ TÀI XẾ -->
                    <h6 class="border-bottom pb-2 mb-3 mt-4">
                        <i class="fas fa-bus"></i> Phân công xe & nhân sự
                    </h6>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">
                                <i class="fas fa-bus"></i> Xe <span class="text-danger">*</span>
                            </label>
                            <select name="busId" class="form-select" required>
                                <option value="">-- Chọn xe --</option>
                                <option th:each="bus : ${buses}" th:value="${bus.id}"
                                    th:text="${bus.licensePlate} + ' (' + ${bus.busType?.typeName} + ')'"
                                    th:selected="${bus.id == trip.bus?.id}">
                                </option>
                            </select>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label class="form-label">
                                <i class="fas fa-user-tie"></i> Tài xế chính <span class="text-danger">*</span>
                            </label>
                            <select name="driverId" class="form-select" required>
                                <option value="">-- Chọn tài xế --</option>
                                <option th:each="driver : ${drivers}" th:value="${driver.userId}"
                                    th:text="${driver.user?.fullName}"
                                    th:selected="${driver.userId == trip.driver?.userId}">
                                </option>
                            </select>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label class="form-label">
                                <i class="fas fa-user"></i> Phụ xe (tùy chọn)
                            </label>
                            <select name="assistantId" class="form-select">
                                <option value="">-- Không có --</option>
                                <option th:each="driver : ${drivers}" th:value="${driver.userId}"
                                    th:text="${driver.user?.fullName}"
                                    th:selected="${driver.userId == trip.assistant?.userId}">
                                </option>
                            </select>
                        </div>
                    </div>

                    <!-- THỜI GIAN -->
                    <h6 class="border-bottom pb-2 mb-3 mt-4">
                        <i class="fas fa-clock"></i> Thời gian
                    </h6>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">
                                <i class="fas fa-calendar-day"></i> Thời gian khởi hành <span
                                    class="text-danger">*</span>
                            </label>
                            <input type="datetime-local" name="departureTime" class="form-control" required
                                th:value="${#temporals.format(trip.departureTime, 'yyyy-MM-dd''T''HH:mm')}">
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">
                                <i class="fas fa-calendar-check"></i> Thời gian đến dự kiến <span
                                    class="text-danger">*</span>
                            </label>
                            <input type="datetime-local" name="arrivalTimeExpected" class="form-control" required
                                th:value="${#temporals.format(trip.arrivalTimeExpected, 'yyyy-MM-dd''T''HH:mm')}">
                        </div>
                    </div>

                    <!-- GHẾ VÀ GIÁ -->
                    <h6 class="border-bottom pb-2 mb-3 mt-4">
                        <i class="fas fa-tags"></i> Ghế ngồi & Giá vé
                    </h6>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">
                                <i class="fas fa-chair"></i> Tổng số ghế <span class="text-danger">*</span>
                            </label>
                            <input type="number" name="totalSeats" class="form-control" required min="1" max="100"
                                th:value="${trip.totalSeats}">
                            <div class="form-text">
                                Đã bán: <strong th:text="${trip.ticketsSold}"></strong> ghế
                            </div>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">
                                <i class="fas fa-dollar-sign"></i> Giá vé (VNĐ) <span class="text-danger">*</span>
                            </label>
                            <input type="number" name="price" class="form-control" required min="0" step="1000"
                                th:value="${trip.price}">
                        </div>
                    </div>

                    <!-- TRẠNG THÁI -->
                    <h6 class="border-bottom pb-2 mb-3 mt-4">
                        <i class="fas fa-info-circle"></i> Trạng thái
                    </h6>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">
                                Trạng thái chuyến <span class="text-danger">*</span>
                            </label>
                            <select name="status" class="form-select" required>
                                <option th:each="status : ${statuses}" th:value="${status.name()}"
                                    th:text="${status.name()}" th:selected="${status == trip.status}">
                                </option>
                            </select>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Loại chuyến</label>
                            <input type="text" class="form-control" readonly
                                th:value="${trip.isExtraTrip ? 'Chuyến tăng cường' : 'Chuyến thường'}">
                        </div>
                    </div>

                    <!-- THỐNG KÊ -->
                    <div class="alert alert-info">
                        <h6><i class="fas fa-chart-bar"></i> Thống kê chuyến:</h6>
                        <div class="row">
                            <div class="col-md-6">
                                <ul class="mb-0">
                                    <li><strong>Tỷ lệ lấp đầy:</strong> <span
