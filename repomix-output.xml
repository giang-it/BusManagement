                                </td>
                                <td th:text="${#temporals.format(trip.departureTime, 'dd/MM/yyyy HH:mm')}"></td>
                                <td>
                                    <span th:text="${trip.ticketsSold} + '/' + ${trip.totalSeats}"></span>
                                    <small
                                        th:text="'(' + ${#numbers.formatDecimal(trip.getOccupancyRate() * 100, 1, 0)} + '%)'"></small>
                                </td>
                                <td th:text="${#numbers.formatDecimal(trip.price, 1, 'COMMA', 0, 'POINT')} + 'đ'"></td>
