<file path="BusManagement/src/main/resources/templates/admin/bus-type-form.html">
<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Form Loại xe</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
</head>

<body class="bg-light">
    <nav class="navbar navbar-dark bg-dark mb-4">
        <div class="container-fluid">
            <span class="navbar-brand mb-0 h1">
                <i class="fas fa-bus"></i>
                <span th:text="${busType.id != null ? 'Sửa loại xe' : 'Thêm loại xe mới'}"></span>
            </span>
            <a href="/admin/master-data/bus-types" class="btn btn-outline-light btn-sm">
                <i class="fas fa-arrow-left"></i> Quay lại
            </a>
        </div>
    </nav>

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card shadow">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0">
                            <i class="fas fa-edit"></i> Thông tin loại xe
                        </h5>
                    </div>
                    <div class="card-body">
                        <form th:action="@{/admin/master-data/bus-types/save}" th:object="${busType}" method="post">
                            <input type="hidden" th:field="*{id}">

                            <!-- Tên loại xe -->
                            <div class="mb-3">
                                <label class="form-label">
                                    <i class="fas fa-tag"></i> Tên loại xe <span class="text-danger">*</span>
                                </label>
                                <input type="text" class="form-control" th:field="*{typeName}" required
                                    placeholder="VD: Giường nằm, Ghế ngồi, Limousine">
                                <div class="form-text">Tên phân loại xe (phải là duy nhất)</div>
                            </div>

                            <!-- Số ghế -->
                            <div class="mb-3">
                                <label class="form-label">
                                    <i class="fas fa-chair"></i> Số ghế <span class="text-danger">*</span>
                                </label>
                                <input type="number" class="form-control" th:field="*{capacity}" required min="1"
                                    max="100" placeholder="40">
                                <div class="form-text">Số lượng ghế/giường của loại xe này</div>
                            </div>

                            <!-- Ví dụ -->
                            <div class="card bg-light mb-3">
                                <div class="card-header">
                                    <i class="fas fa-lightbulb"></i> Ví dụ các loại xe phổ biến
                                </div>
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <strong>Giường nằm:</strong>
                                            <ul class="mb-0">
                                                <li>40-46 giường (2 tầng)</li>
                                                <li>Cho tuyến dài > 300km</li>
                                            </ul>
                                        </div>
                                        <div class="col-md-6">
                                            <strong>Ghế ngồi:</strong>
                                            <ul class="mb-0">
                                                <li>29-45 ghế</li>
                                                <li>Cho tuyến ngắn < 300km</li>
                                            </ul>
                                        </div>
                                    </div>
                                    <div class="row mt-2">
                                        <div class="col-md-6">
                                            <strong>Limousine:</strong>
                                            <ul class="mb-0">
                                                <li>9-24 ghế cao cấp</li>
                                                <li>Có massage, giải trí</li>
                                            </ul>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="d-flex justify-content-between mt-4">
                                <a href="/admin/master-data/bus-types" class="btn btn-secondary">
                                    <i class="fas fa-times"></i> Hủy
                                </a>
                                <button type="submit" class="btn btn-success">
                                    <i class="fas fa-save"></i> Lưu
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
</file>

<file path="BusManagement/src/main/resources/templates/admin/bus-type-list.html">
<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý Loại xe</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
</head>

<body class="bg-light">
    <nav class="navbar navbar-dark bg-dark mb-4">
        <div class="container-fluid">
            <span class="navbar-brand mb-0 h1">
                <i class="fas fa-bus"></i> Quản lý Loại xe
            </span>
            <a href="/admin/dashboard" class="btn btn-outline-light btn-sm">
                <i class="fas fa-home"></i> Dashboard
            </a>
        </div>
    </nav>

    <div class="container">
        <!-- Alert Messages -->
        <div th:if="${success}" class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> <span th:text="${success}"></span>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>

        <div th:if="${error}" class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle"></i> <span th:text="${error}"></span>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>

        <!-- Statistics -->
        <div class="row mb-4">
            <div class="col-md-12">
                <div class="card border-success">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-1">Tổng số loại xe</h6>
                                <h3 class="mb-0" th:text="${busTypes.size()}">0</h3>
                            </div>
                            <div style="font-size: 3rem; opacity: 0.7;" class="text-success">
                                <i class="fas fa-layer-group"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Danh sách loại xe -->
        <div class="card shadow">
            <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="fas fa-list"></i> Danh sách loại xe
                </h5>
                <a href="/admin/master-data/bus-types/form" class="btn btn-light btn-sm">
                    <i class="fas fa-plus"></i> Thêm loại xe mới
                </a>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>ID</th>
                                <th>Tên loại xe</th>
                                <th>Số ghế</th>
                                <th>Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr th:each="busType : ${busTypes}">
                                <td th:text="${busType.id}"></td>
                                <td>
                                    <i class="fas fa-bus text-success"></i>
                                    <strong th:text="${busType.typeName}"></strong>
                                </td>
                                <td>
                                    <span class="badge bg-info" th:text="${busType.capacity} + ' ghế'"></span>
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm" role="group">
                                        <a th:href="@{/admin/master-data/bus-types/form(id=${busType.id})}"
                                            class="btn btn-outline-primary" title="Sửa">
                                            <i class="fas fa-edit"></i> Sửa
                                        </a>
                                        <form th:action="@{/admin/master-data/bus-types/delete/{id}(id=${busType.id})}"
                                            method="post" style="display: inline;">
                                            <button type="submit" class="btn btn-outline-danger btn-sm"
                                                onclick="return confirm('Xác nhận xóa loại xe này?')" title="Xóa">
                                                <i class="fas fa-trash"></i> Xóa
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                            <tr th:if="${busTypes.isEmpty()}">
                                <td colspan="4" class="text-center text-muted py-5">
                                    <i class="fas fa-info-circle fs-3"></i><br>
                                    Chưa có loại xe nào trong hệ thống. Hãy thêm loại xe mới!
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Info box -->
        <div class="alert alert-info mt-4">
            <i class="fas fa-info-circle"></i>
            <strong>Về Loại xe:</strong>
            <ul class="mb-0 mt-2">
                <li><strong>Giường nằm:</strong> Thường dùng cho tuyến dài (> 300km), số ghế khoảng 40-46</li>
                <li><strong>Ghế ngồi:</strong> Thường dùng cho tuyến ngắn, số ghế khoảng 29-45</li>
                <li><strong>Limousine:</strong> Cao cấp, 9-24 ghế, thường có massage và giải trí</li>
            </ul>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
</file>

