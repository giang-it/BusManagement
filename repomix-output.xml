                <span class="badge bg-primary me-2 ms-3">DEPARTED</span> Đã khởi hành
                <span class="badge bg-info me-2 ms-3">COMPLETED</span> Hoàn thành
                <span class="badge bg-danger me-2 ms-3">CANCELLED</span> Đã hủy
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
