<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">

<head>
    <title>Chuyến xe chờ phê duyệt</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        .auto-assigned {
            border-left: 4px solid #198754;
        }

        .needs-manual {
            border-left: 4px solid #fd7e14;
        }
    </style>
</head>

<body class="container mt-4">

    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h2 class="mb-0">🤖 Chuyến tăng cường chờ phê duyệt</h2>
            <small class="text-muted">AI tự động tạo khi tỉ lệ lấp đầy ghế &gt; 90%</small>
        </div>
        <a href="/admin/trip-management/trips" class="btn btn-outline-secondary">← Quản lý chuyến xe</a>
    </div>

    <!-- Flash messages -->
    <div th:if="${success}" class="alert alert-success alert-dismissible fade show">
        <span th:text="${success}"></span>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    <div th:if="${error}" class="alert alert-danger alert-dismissible fade show">
        <span th:text="${error}"></span>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>

    <!-- Không có chuyến nào chờ -->
    <div th:if="${#lists.isEmpty(pendingTrips)}" class="text-center py-5 text-muted">
        <div style="font-size:3rem">✅</div>
        <h5 class="mt-2">Không có chuyến nào cần xử lý</h5>
        <p>Hệ thống AI đang theo dõi tự động. Trang sẽ cập nhật khi có đề xuất mới.</p>
    </div>

    <!-- Thống kê nhanh -->
    <div th:unless="${#lists.isEmpty(pendingTrips)}" class="row mb-4">
        <div class="col-md-4">
            <div class="card text-center border-0 bg-success bg-opacity-10">
                <div class="card-body py-2">
                    <div class="fs-4 fw-bold text-success" th:text="${autoAssignedCount}"></div>
                    <small class="text-muted">Đã phân công tự động</small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center border-0 bg-warning bg-opacity-10">
                <div class="card-body py-2">
                    <div class="fs-4 fw-bold text-warning" th:text="${needsManualCount}"></div>
                    <small class="text-muted">Cần xử lý thủ công</small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center border-0 bg-secondary bg-opacity-10">
                <div class="card-body py-2">
                    <div class="fs-4 fw-bold" th:text="${#lists.size(pendingTrips)}"></div>
                    <small class="text-muted">Tổng chuyến chờ duyệt</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Danh sách chuyến -->
    <div th:each="trip : ${pendingTrips}" class="card mb-3"
        th:classappend="${trip.bus != null and trip.driver != null} ? 'auto-assigned' : 'needs-manual'">
        <div class="card-body">
            <div class="row align-items-center">

                <!-- Thông tin chuyến -->
                <div class="col-md-4">
                    <div class="fw-bold" th:text="${trip.route.departurePoint + ' → ' + trip.route.destinationPoint}">
                    </div>
                    <div class="text-muted small"
                        th:text="'Khởi hành: ' + ${#temporals.format(trip.departureTime, 'HH:mm - dd/MM/yyyy')}">
                    </div>
                    <div class="text-muted small" th:text="'Số ghế: ' + ${trip.totalSeats}">
                    </div>
                </div>

                <!-- Trạng thái phân công AI -->
                <div class="col-md-5">

                    <!-- ĐÃ PHÂN CÔNG TỰ ĐỘNG -->
                    <div th:if="${trip.bus != null and trip.driver != null}">
                        <div class="badge bg-success mb-1">🤖 AI đã phân công</div>
                        <div class="small">
                            <span class="me-2">🚌 <strong th:text="${trip.bus.licensePlate}"></strong></span>
                            <span class="me-2">👨‍✈️ <span th:text="${trip.driver.user.fullName}"></span></span>
                            <span th:if="${trip.assistant != null}">
                                🧑‍🔧 <span th:text="${trip.assistant.user.fullName}"></span>
                            </span>
                            <span th:unless="${trip.assistant != null}" class="text-muted">
                                (Không có phụ xe)
                            </span>
                        </div>
                    </div>

                    <!-- CẦN XỬ LÝ THỦ CÔNG -->
                    <div th:unless="${trip.bus != null and trip.driver != null}">
                        <div class="badge bg-warning text-dark mb-1">⚠️ Cần phân công thủ công</div>
                        <div class="small text-muted">
                            AI không tìm đủ tài nguyên trong khung giờ này.
                            Nhấn "Xem & Phân công" để chọn thủ công.
                        </div>
                    </div>
                </div>

                <!-- Nút hành động -->
                <div class="col-md-3 text-end">
                    <!-- Confirm 1-click nếu AI đã phân công đầy đủ -->
                    <div th:if="${trip.bus != null and trip.driver != null}" class="d-flex gap-2 justify-content-end">
                        <form th:action="@{/admin/trips/confirm}" method="post">
                            <input type="hidden" name="tripId" th:value="${trip.id}">
                            <button type="submit" class="btn btn-success btn-sm">
                                ✅ Xác nhận
                            </button>
                        </form>
                        <a th:href="@{/admin/trips/approve/{id}(id=${trip.id})}"
                            class="btn btn-outline-secondary btn-sm">Chi tiết</a>
                    </div>

                    <!-- Xem & phân công thủ công -->
                    <div th:unless="${trip.bus != null and trip.driver != null}">
                        <a th:href="@{/admin/trips/approve/{id}(id=${trip.id})}" class="btn btn-warning btn-sm">🔧 Xem &
                            Phân công</a>
                    </div>

                    <!-- Từ chối (cả 2 mode) -->
                    <form th:action="@{/admin/trips/reject/{id}(id=${trip.id})}" method="post" class="mt-2"
                        onsubmit="return confirm('Từ chối chuyến tăng cường này?')">
                        <button type="submit" class="btn btn-outline-danger btn-sm w-100">Từ chối</button>
                    </form>
                </div>

            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
</file>

<file path="BusManagement/src/main/resources/templates/admin/trip-create-form.html">
<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tạo Chuyến xe</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
</head>

<body class="bg-light">
    <nav class="navbar navbar-dark bg-dark mb-4">
        <div class="container-fluid">
            <span class="navbar-brand mb-0 h1">
                <i class="fas fa-plus-circle"></i> Tạo Chuyến xe thủ công
            </span>
            <a href="/admin/trip-management/trips" class="btn btn-outline-light btn-sm">
                <i class="fas fa-arrow-left"></i> Quay lại
            </a>
        </div>
    </nav>

    <div class="container">
        <!-- Alert Messages -->
        <div th:if="${success}" class="alert alert-success alert-dismissible fade show mt-3" role="alert">
            <i class="fas fa-check-circle"></i> <span th:text="${success}"></span>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>

        <div th:if="${error}" class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
            <i class="fas fa-exclamation-circle"></i> <span th:text="${error}"></span>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>

        <div class="card shadow mt-3">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0">
                    <i class="fas fa-edit"></i> Thông tin chuyến xe
                </h5>
            </div>
            <div class="card-body">
                <form action="/admin/trip-management/trips/create" method="post">

                    <!-- CHỌN TUYẾN -->
                    <h6 class="border-bottom pb-2 mb-3">
                        <i class="fas fa-route"></i> Thông tin tuyến đường
                    </h6>
                    <div class="row">
                        <div class="col-md-12 mb-3">
                            <label class="form-label">
                                Tuyến đường <span class="text-danger">*</span>
                            </label>
                            <select name="routeId" class="form-select" required>
                                <option value="">-- Chọn tuyến --</option>
                                <option th:each="route : ${routes}" th:value="${route.id}"
                                    th:text="${route.departurePoint} + ' → ' + ${route.destinationPoint}">
                                </option>
                            </select>
                        </div>
                    </div>

                    <!-- CHỌN XE VÀ TÀI XẾ -->
                    <h6 class="border-bottom pb-2 mb-3 mt-4">
                        <i class="fas fa-bus"></i> Phân công xe & nhân sự
                    </h6>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">
                                <i class="fas fa-bus"></i> Xe <span class="text-danger">*</span>
                            </label>
                            <select name="busId" class="form-select" required>
                                <option value="">-- Chọn xe --</option>
                                <option th:each="bus : ${buses}" th:value="${bus.id}"
                                    th:text="${bus.licensePlate} + ' (' + ${bus.busType?.typeName} + ')'">
                                </option>
                            </select>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label class="form-label">
                                <i class="fas fa-user-tie"></i> Tài xế chính <span class="text-danger">*</span>
                            </label>
                            <select name="driverId" class="form-select" required>
                                <option value="">-- Chọn tài xế --</option>
                                <option th:each="driver : ${drivers}" th:value="${driver.userId}"
                                    th:text="${driver.user?.fullName}">
                                </option>
                            </select>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label class="form-label">
                                <i class="fas fa-user"></i> Phụ xe (tùy chọn)
                            </label>
                            <select name="assistantId" class="form-select">
                                <option value="">-- Không có --</option>
                                <option th:each="driver : ${drivers}" th:value="${driver.userId}"
                                    th:text="${driver.user?.fullName}">
                                </option>
                            </select>
                            <div class="form-text">Phụ xe hỗ trợ bán vé và chăm sóc khách</div>
                        </div>
                    </div>

                    <!-- TÀI XẾ PHỤ ĐỘNG (hiện khi chuyến > 8h) -->
                    <div id="coDriverSection" class="mt-3" style="display:none;">
                        <div class="alert alert-info d-flex align-items-center gap-2 py-2 mb-3">
                            <i class="fas fa-info-circle fs-5"></i>
                            <div>
                                <strong>Chuyến dài — cần thêm tài xế phụ!</strong>
                                <span id="coDriverInfo" class="ms-1 text-muted"></span>
                            </div>
                        </div>
                        <div id="coDriverSlots"></div>
                        <button type="button" class="btn btn-outline-secondary btn-sm mt-1" onclick="addCoDriverSlot()">
                            <i class="fas fa-plus"></i> Thêm tài xế phụ
                        </button>
                    </div>

                    <!-- THỜI GIAN -->
                    <h6 class="border-bottom pb-2 mb-3 mt-4">
                        <i class="fas fa-clock"></i> Thời gian
                    </h6>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">
                                <i class="fas fa-calendar-day"></i> Thời gian khởi hành <span
                                    class="text-danger">*</span>
                            </label>
                            <input type="datetime-local" name="departureTime" class="form-control" required>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">
                                <i class="fas fa-calendar-check"></i> Thời gian đến dự kiến <span
                                    class="text-danger">*</span>
                            </label>
                            <input type="datetime-local" name="arrivalTimeExpected" class="form-control" required>
                        </div>
                    </div>

                    <!-- GHẾ VÀ GIÁ -->
                    <h6 class="border-bottom pb-2 mb-3 mt-4">
                        <i class="fas fa-tags"></i> Ghế ngồi & Giá vé
                    </h6>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">
                                <i class="fas fa-chair"></i> Tổng số ghế <span class="text-danger">*</span>
                            </label>
                            <input type="number" name="totalSeats" class="form-control" required min="1" max="100"
                                placeholder="40">
                            <div class="form-text">Số ghế thực tế trên xe</div>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">
                                <i class="fas fa-dollar-sign"></i> Giá vé (VNĐ) <span class="text-danger">*</span>
                            </label>
                            <input type="number" name="price" class="form-control" required min="0" step="1000"
                                placeholder="150000">
                            <div class="form-text">Giá vé một ghế</div>
                        </div>
                    </div>

                    <!-- CẢNH BÁO -->
                    <div class="alert alert-warning">
                        <h6><i class="fas fa-exclamation-triangle"></i> Lưu ý khi tạo chuyến:</h6>
                        <ul class="mb-0">
                            <li><strong>Xe:</strong> Đảm bảo xe đang ở trạng thái READY (không trong bảo trì)</li>
                            <li><strong>Tài xế:</strong> Kiểm tra tài xế chưa lái quá 8h trong 24h qua</li>
                            <li><strong>Chuyến &gt; 8h:</strong> Cần thêm tài xế phụ — hệ thống tự tính và hiển thị phía trên</li>
                            <li><strong>Chuyến &gt; 8h:</strong> Phụ xe là <strong>BẮT BUỘC</strong></li>
                            <li><strong>Thời gian:</strong> Thời gian đến phải sau thời gian khởi hành</li>
                            <li><strong>Ghế:</strong> Số ghế phải khớp với xe được chọn</li>
                        </ul>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <a href="/admin/trip-management/trips" class="btn btn-secondary">
                            <i class="fas fa-times"></i> Hủy
                        </a>
                        <button type="submit" class="btn btn-success">
                            <i class="fas fa-save"></i> Tạo chuyến
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Hướng dẫn -->
        <div class="card mt-4">
            <div class="card-header bg-info text-white">
                <h6 class="mb-0"><i class="fas fa-question-circle"></i> Hướng dẫn</h6>
            </div>
            <div class="card-body">
                <ol>
                    <li><strong>Chọn tuyến:</strong> Chọn tuyến đường đã được cấu hình sẵn</li>
                    <li><strong>Gán xe & tài xế:</strong> Hệ thống sẽ kiểm tra ràng buộc tự động</li>
                    <li><strong>Phụ xe:</strong> Tùy chọn, giúp hỗ trợ bán vé và chăm sóc khách</li>
                    <li><strong>Đặt thời gian:</strong> Thời gian khởi hành phải là tương lai</li>
                    <li><strong>Giá vé:</strong> Có thể tham khảo bảng giá đã cấu hình cho tuyến</li>
                </ol>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Danh sách tài xế từ server (dùng cho các slot tài xế phụ)
        const ALL_DRIVERS = [
            /*[# th:each="d : ${drivers}"]
            { id: /*[[${d.userId}]]*/ 0, name: /*[[${d.user?.fullName}]]*/ '' },
            /*[/]*/
        ];

        // Inline Thymeleaf để tạo mảng JS
        const driversData = [];
    </script>
    <script th:inline="javascript">
        /*<![CDATA[*/
        const driversForJs = /*[[${drivers}]]*/ [];
        /*]]>*/

        let coDriverCount = 0;

        function calcDurationHours() {
            const dep = document.querySelector('[name="departureTime"]').value;
            const arr = document.querySelector('[name="arrivalTimeExpected"]').value;
            if (!dep || !arr) return 0;
            const diff = (new Date(arr) - new Date(dep)) / 3600000;
            return diff > 0 ? diff : 0;
        }

        function buildDriverOption(d, selectedId) {
            const sel = selectedId && String(d.userId) === String(selectedId) ? ' selected' : '';
            return `<option value="${d.userId}"${sel}>${d.user ? d.user.fullName : d.userId}</option>`;
        }

        function updateCoDriverSection() {
            const durationHours = calcDurationHours();
            const requiredDrivers = durationHours > 0 ? Math.ceil(durationHours / 8.0) : 1;
            const neededCoDrivers = requiredDrivers - 1; // trừ tài xế chính

            const section = document.getElementById('coDriverSection');
            const info = document.getElementById('coDriverInfo');
            const slotsDiv = document.getElementById('coDriverSlots');

            if (neededCoDrivers <= 0) {
                section.style.display = 'none';
                slotsDiv.innerHTML = '';
                coDriverCount = 0;
                return;
            }

            section.style.display = 'block';
            info.textContent = `(Chuyến ${durationHours.toFixed(1)}h → cần ít nhất ${requiredDrivers} tài xế, tối thiểu ${neededCoDrivers} tài xế phụ)`;

            // Đảm bảo đủ slots tối thiểu
            while (coDriverCount < neededCoDrivers) {
                addCoDriverSlot();
            }
        }

        function addCoDriverSlot() {
            coDriverCount++;
            const slotsDiv = document.getElementById('coDriverSlots');
            const idx = coDriverCount;

            let options = '<option value="">-- Chọn tài xế phụ --</option>';
            driversForJs.forEach(d => {
                const name = d.user ? d.user.fullName : ('ID:' + d.userId);
                options += `<option value="${d.userId}">${name}</option>`;
            });

            const div = document.createElement('div');
            div.className = 'row mb-2 align-items-center';
            div.id = `coDriverRow_${idx}`;
            div.innerHTML = `
                <div class="col">
                    <label class="form-label"><i class="fas fa-user-shield"></i> Tài xế phụ ${idx}</label>
                    <select name="coDriverIds" class="form-select form-select-sm">
                        ${options}
                    </select>
                </div>
                <div class="col-auto" style="padding-top:28px">
                    <button type="button" class="btn btn-outline-danger btn-sm" onclick="removeCoDriverSlot(${idx})">
                        <i class="fas fa-trash"></i>
                    </button>
                </div>`;
            slotsDiv.appendChild(div);
        }

        function removeCoDriverSlot(idx) {
            const row = document.getElementById(`coDriverRow_${idx}`);
            if (row) row.remove();
        }

        // Gắn listener
        document.querySelector('[name="departureTime"]').addEventListener('change', updateCoDriverSection);
        document.querySelector('[name="arrivalTimeExpected"]').addEventListener('change', updateCoDriverSection);
    </script>
</body>

</html>
</file>

<file path="BusManagement/src/main/resources/templates/admin/trip-list.html">
<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý chuyến xe</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <style>
        :root {
            --primary: #4F46E5;
            --primary-hover: #4338CA;
            --bg-color: #F3F4F6;
            --card-bg: rgba(255, 255, 255, 0.85);
            --text-main: #1F2937;
            --text-muted: #6B7280;
            --border-color: rgba(229, 231, 235, 0.5);

            --success-color: #10B981;
            --warning-color: #F59E0B;
            --info-color: #3B82F6;
            --danger-color: #EF4444;
            --neutral-color: #9CA3AF;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #fdfbfb 0%, #ebedee 100%);
            color: var(--text-main);
            min-height: 100vh;
            padding-bottom: 2rem;
        }

        /* Navbar Styling */
        .navbar-premium {
            background: rgba(17, 24, 39, 0.95);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            padding: 1rem 0;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }

        .navbar-brand {
            font-weight: 700;
            letter-spacing: 0.5px;
            font-size: 1.25rem;
        }

        /* Glassmorphism Card */
        .glass-card {
            background: var(--card-bg);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.6);
            border-radius: 1rem;
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05), 0 8px 10px -6px rgba(0, 0, 0, 0.01);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .card-header-premium {
            background: transparent;
            border-bottom: 1px solid var(--border-color);
            padding: 1.25rem 1.5rem;
        }

        /* Table Styling */
        .table {
            margin-bottom: 0;
            color: var(--text-main);
        }

        .table th {
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.05em;
            color: var(--text-muted);
            border-bottom: 2px solid var(--border-color);
            padding: 1rem 1.5rem;
            background: rgba(249, 250, 251, 0.5);
        }

        .table td {
            padding: 1.25rem 1.5rem;
            vertical-align: middle;
            border-bottom: 1px solid var(--border-color);
            font-size: 0.9rem;
        }

        .table tbody tr {
            transition: all 0.2s ease;
        }

        .table tbody tr:hover {
            background-color: rgba(243, 244, 246, 0.8);
            transform: scale(1.002);
        }

        /* Buttons & Inputs */
        .btn-premium {
            background: linear-gradient(135deg, var(--primary) 0%, #6366F1 100%);
            color: white;
            border: none;
            border-radius: 0.5rem;
            padding: 0.5rem 1.25rem;
            font-weight: 500;
            transition: all 0.2s ease;
            box-shadow: 0 4px 6px -1px rgba(79, 70, 229, 0.2);
        }

        .btn-premium:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 8px -1px rgba(79, 70, 229, 0.3);
            color: white;
        }

        .btn-outline-premium {
            border: 1px solid rgba(255, 255, 255, 0.3);
            color: white;
            border-radius: 0.5rem;
            transition: all 0.2s ease;
        }

        .btn-outline-premium:hover {
            background: rgba(255, 255, 255, 0.1);
            color: white;
            transform: translateY(-1px);
        }

        .form-select-premium {
            border-radius: 0.5rem;
            border: 1px solid #D1D5DB;
            padding: 0.5rem 2.25rem 0.5rem 1rem;
            font-size: 0.9rem;
            box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        .form-select-premium:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.1);
        }

        /* Status Pills */
        .status-pill {
            display: inline-flex;
            align-items: center;
            padding: 0.25rem 0.75rem;
            border-radius: 9999px;
            font-size: 0.75rem;
            font-weight: 600;
            line-height: 1.25rem;
        }

        .status-dot {
            width: 0.5rem;
            height: 0.5rem;
            border-radius: 50%;
            margin-right: 0.375rem;
        }

        .status-active {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success-color);
        }

        .status-active .status-dot {
            background-color: var(--success-color);
        }

        .status-pending {
            background: rgba(245, 158, 11, 0.1);
            color: var(--warning-color);
        }

        .status-pending .status-dot {
            background-color: var(--warning-color);
        }

        .status-departed {
            background: rgba(59, 130, 246, 0.1);
            color: var(--info-color);
        }

        .status-departed .status-dot {
            background-color: var(--info-color);
        }

        .status-completed {
            background: rgba(156, 163, 175, 0.1);
            color: var(--neutral-color);
        }

        .status-completed .status-dot {
            background-color: var(--neutral-color);
        }

        .status-cancelled {
            background: rgba(239, 68, 68, 0.1);
            color: var(--danger-color);
            text-decoration: line-through;
            opacity: 0.8;
        }

        .status-cancelled .status-dot {
            background-color: var(--danger-color);
        }

        .badge-extra {
            background: linear-gradient(135deg, #06b6d4 0%, #3b82f6 100%);
            font-weight: 500;
            padding: 0.35em 0.65em;
            border-radius: 0.375rem;
            font-size: 0.7rem;
        }

        /* Action Buttons */
        .action-btn {
            width: 32px;
            height: 32px;
            padding: 0;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 0.375rem;
            transition: all 0.2s ease;
            border: 1px solid transparent;
            background: transparent;
        }

        .btn-edit {
            color: var(--primary);
        }

        .btn-edit:hover {
            background: rgba(79, 70, 229, 0.1);
            color: var(--primary-hover);
            transform: scale(1.05);
        }

        .btn-cancel {
            color: var(--warning-color);
        }

        .btn-cancel:hover {
            background: rgba(245, 158, 11, 0.1);
            color: #D97706;
            transform: scale(1.05);
        }

        .btn-delete {
            color: var(--danger-color);
        }

        .btn-delete:hover {
            background: rgba(239, 68, 68, 0.1);
            color: #B91C1C;
            transform: scale(1.05);
        }

        /* Animation */
        .fade-in-up {
            animation: fadeInUp 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>

<body>
    <!-- Premium Navbar -->
    <nav class="navbar navbar-premium mb-5">
        <div class="container-fluid px-4">
            <span class="navbar-brand text-white d-flex align-items-center gap-2">
                <i class="bi bi-rocket-takeoff text-primary fs-4"></i>
                Hệ Thống Điều Hành Chuyến
            </span>
            <div class="d-flex gap-3">
                <a href="/admin/trip-management/trips/create" class="btn btn-premium d-flex align-items-center gap-2">
                    <i class="bi bi-plus-lg"></i> Thêm Chuyến Mới
                </a>
                <a href="/admin/dashboard" class="btn btn-outline-premium d-flex align-items-center gap-2">
                    <i class="bi bi-box-arrow-left"></i> Dashboard
                </a>
            </div>
        </div>
    </nav>

    <div class="container-fluid px-4 fade-in-up">
        <!-- Alerts -->
        <div th:if="${success}"
            class="alert alert-success alert-dismissible fade show glass-card border-success border-opacity-25"
            role="alert">
            <i class="bi bi-check-circle-fill me-2 text-success"></i> <span th:text="${success}"></span>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
        <div th:if="${error}"
            class="alert alert-danger alert-dismissible fade show glass-card border-danger border-opacity-25"
            role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2 text-danger"></i> <span th:text="${error}"></span>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
        <div th:if="${warning}"
            class="alert alert-warning alert-dismissible fade show glass-card border-warning border-opacity-25"
            role="alert">
            <i class="bi bi-exclamation-circle-fill me-2 text-warning"></i> <span th:text="${warning}"></span>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>

        <!-- Filter Bar -->
        <div class="glass-card mb-4 p-3 d-flex flex-wrap justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-2 text-muted">
                <i class="bi bi-funnel fs-5"></i>
                <span class="fw-medium">Bộ lọc hiển thị</span>
            </div>

            <form action="/admin/trip-management/trips/filter" method="get" class="d-flex align-items-center gap-3 m-0">
                <select name="status" class="form-select form-select-premium" style="width: 220px;"
                    onchange="this.form.submit()">
                    <option value="">Tất cả trạng thái</option>
                    <option th:each="st : ${statuses}" th:value="${st.name()}" th:text="${st.name()}"
                        th:selected="${st.name() == selectedStatus}"></option>
                </select>
                <noscript>
                    <button type="submit" class="btn btn-premium">Lọc</button>
                </noscript>
            </form>
        </div>

        <!-- Data Table -->
        <div class="glass-card overflow-hidden">
            <div class="card-header-premium d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold d-flex align-items-center gap-2">
                    <i class="bi bi-list-columns-reverse text-primary"></i>
                    Danh sách chi tiết
                </h5>
                <span class="badge rounded-pill bg-light text-dark border px-3 py-2 fw-medium"
                    style="font-size: 0.85rem;">
                    <span th:text="${#lists.size(trips)}"></span> Chuyến
                </span>
            </div>

            <div class="table-responsive">
                <div th:if="${#lists.isEmpty(trips)}" class="text-center py-5 text-muted">
                    <i class="bi bi-inbox fs-1 text-secondary opacity-50"></i>
                    <p class="mt-3 fw-medium">Chưa có dữ liệu chuyến xe nào.</p>
                </div>

                <table th:unless="${#lists.isEmpty(trips)}" class="table table-borderless align-middle mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4" style="width: 5%">Mã</th>
                            <th style="width: 20%">Tuyến Đường</th>
                            <th style="width: 12%">Phương Tiện</th>
                            <th style="width: 15%">Tài Xế Chính</th>
                            <th style="width: 15%">Phụ Xe</th>
                            <th style="width: 12%">Khởi Hành</th>
                            <th style="width: 8%">Tỷ Lệ Đặt</th>
                            <th style="width: 8%">Trạng Thái</th>
                            <th class="text-end pe-4" style="width: 5%">Thao Tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr th:each="trip : ${trips}">
                            <td class="ps-4 fw-medium text-muted">#<span th:text="${trip.id}"></span></td>
                            <td>
                                <div class="fw-semibold text-main">
                                    <span th:text="${trip.route.departurePoint}"></span>
                                    <i class="bi bi-arrow-right-short text-muted mx-1"></i>
                                    <span th:text="${trip.route.destinationPoint}"></span>
                                </div>
                                <span th:if="${trip.isExtraTrip}" class="badge badge-extra mt-1">
                                    <i class="bi bi-lightning-fill"></i> Tăng cường
                                </span>
                            </td>
                            <td>
                                <div th:if="${trip.bus != null}" class="fw-medium">
                                    <span th:text="${trip.bus.licensePlate}"></span>
                                </div>
                                <span th:unless="${trip.bus != null}" class="badge bg-light text-secondary border">Chưa
                                    gán</span>
                            </td>
                            <td>
                                <div th:if="${trip.driver != null}">
                                    <span class="fw-medium" th:text="${trip.driver.user.fullName}"></span>
                                </div>
                                <span th:unless="${trip.driver != null}" class="text-muted fst-italic fs-6">Chưa
                                    gán</span>
                            </td>
                            <td>
                                <div th:if="${trip.assistant != null}">
                                    <span class="text-muted" th:text="${trip.assistant.user.fullName}"></span>
                                </div>
                                <span th:unless="${trip.assistant != null}" class="text-muted opacity-50">—</span>
                            </td>
                            <td>
                                <div class="fw-medium" th:text="${#temporals.format(trip.departureTime, 'HH:mm')}">
                                </div>
                                <div class="text-muted small"
                                    th:text="${#temporals.format(trip.departureTime, 'dd/MM/yyyy')}"></div>
                            </td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="fw-medium"
                                        th:text="${trip.ticketsSold + '/' + trip.totalSeats}"></span>
                                    <span class="small"
                                        th:classappend="${trip.getOccupancyRate() > 0.8 ? 'text-success fw-bold' : 'text-muted'}"
                                        th:text="'(' + ${#numbers.formatDecimal(trip.getOccupancyRate() * 100, 1, 0)} + '%)'"></span>
                                </div>
                            </td>
                            <td>
                                <span th:switch="${trip.status.name()}" class="status-pill status-ACTIVE">
                                    <span th:case="'ACTIVE'" class="status-pill status-active"><span
                                            class="status-dot"></span>ACTIVE</span>
                                    <span th:case="'PENDING_APPROVAL'" class="status-pill status-pending"><span
                                            class="status-dot"></span>PENDING_APPROVAL</span>
                                    <span th:case="'DEPARTED'" class="status-pill status-departed"><span
                                            class="status-dot"></span>DEPARTED</span>
                                    <span th:case="'COMPLETED'" class="status-pill status-completed"><span
                                            class="status-dot"></span>COMPLETED</span>
                                    <span th:case="'CANCELLED'" class="status-pill status-cancelled"><span
                                            class="status-dot"></span>CANCELLED</span>
                                </span>
                            </td>
                            <td class="text-end pe-4">
                                <div class="d-flex justify-content-end gap-1">
                                    <a th:href="@{/admin/trip-management/trips/edit/{id}(id=${trip.id})}"
                                        class="action-btn btn-edit" title="Chỉnh sửa">
                                        <i class="bi bi-pen"></i>
                                    </a>

                                    <form
                                        th:if="${trip.status.name() != 'CANCELLED' and trip.status.name() != 'COMPLETED'}"
                                        th:action="@{/admin/trip-management/trips/cancel/{id}(id=${trip.id})}"
                                        method="post" class="m-0"
                                        onsubmit="return confirm('Bạn có chắc chắn muốn hủy chuyến xe này?')">
                                        <button type="submit" class="action-btn btn-cancel" title="Hủy chuyến">
                                            <i class="bi bi-slash-circle"></i>
                                        </button>
                                    </form>

                                    <form th:if="${trip.ticketsSold == 0}"
                                        th:action="@{/admin/trip-management/trips/delete/{id}(id=${trip.id})}"
                                        method="post" class="m-0"
                                        onsubmit="return confirm('Hành động này không thể hoàn tác. Xóa chuyến xe?')">
                                        <button type="submit" class="action-btn btn-delete" title="Xóa vĩnh viễn">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
