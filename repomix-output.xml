                            <th>Hãng Xe</th>
                            <th>Loại Xe</th>
                            <th>Sức Chứa (Ghế)</th>
                            <th>Odometer (Km)</th>
                            <th>Chạy Từ Lần Bảo Trì Cuối</th>
                            <th>Trạng Thái</th>
                            <th>Cảnh Báo Bảo Dưỡng</th>
                            <th class="text-center">Hành Động</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr th:each="bus : ${buses}">
                            <td th:text="${bus.id}" class="fw-bold text-muted"></td>
                            <td><span class="badge bg-secondary fs-6 text-uppercase"
                                    th:text="${bus.licensePlate}"></span></td>
                            <td th:text="${bus.brand}"></td>
                            <td th:text="${bus.busType != null ? bus.busType.typeName : 'N/A'}"></td>
                            <td><span class="badge bg-info text-dark"
                                    th:text="${bus.busType != null ? bus.busType.capacity + ' Ghế' : 'N/A'}"></span>
                            </td>
                            <td th:text="${#numbers.formatDecimal(bus.odometer, 1, 0)} + ' km'"></td>
                            <td
                                th:text="${#numbers.formatDecimal(bus.getKmSinceLastMaintenance(), 1, 0)} + ' / ' + ${#numbers.formatDecimal(bus.maintenanceThreshold, 1, 0)} + ' km'">
                            </td>
                            <td>
                                <span th:if="${bus.status.name() == 'READY'}" class="badge bg-success">Sẵn Sàng</span>
                                <span th:if="${bus.status.name() == 'TRAVELING'}" class="badge bg-primary">Đang
                                    Chạy</span>
                                <span th:if="${bus.status.name() == 'REPAIRING'}" class="badge bg-warning text-dark">Bảo
                                    Trì</span>
                            </td>
                            <td>
                                <span th:if="${bus.needsMaintenance()}" class="badge bg-danger animate-pulse"><i
                                        class="bi bi-exclamation-octagon"></i> Cần bảo trì gấp!</span>
                                <span th:unless="${bus.needsMaintenance()}"
                                    class="badge bg-light text-success border border-success">An Toàn</span>
                            </td>
                            <td class="text-center">
                                <a th:href="@{/admin/buses/edit/{id}(id=${bus.id})}"
                                    class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil-square"></i> Sửa</a>
                                <a th:href="@{/admin/buses/delete/{id}(id=${bus.id})}"
                                    class="btn btn-sm btn-outline-danger"
                                    onclick="return confirm('Bạn có chắc chắn muốn xóa?');"><i class="bi bi-trash"></i>
                                    Xóa</a>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
