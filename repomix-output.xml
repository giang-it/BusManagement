                    <div class="col-md-4 mb-4">
                        <a th:href="@{/admin/trip-management/trips}"
                            class="btn btn-outline-primary btn-lg w-100 py-4 shadow-sm">
                            <i class="bi bi-calendar-event fs-1"></i><br><span class="mt-2 d-block">Quản Lý Chuyến
                                Xe</span>
                        </a>
                    </div>
                    <div class="col-md-4 mb-4">
                        <a th:href="@{/admin/trips/pending}"
                            class="btn btn-outline-warning btn-lg w-100 py-4 shadow-sm">
